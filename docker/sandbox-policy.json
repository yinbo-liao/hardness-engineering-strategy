{
  "version": "1.0",
  "network": {
    "allowed": false,
    "reason": "Prevent data exfiltration and unauthorized external access"
  },
  "filesystem": {
    "read_only_root": true,
    "writable_paths": ["/workspace", "/tmp/harness"],
    "tmpfs": ["/tmp"],
    "denied_paths": ["/etc", "/root", "/home"]
  },
  "resources": {
    "cpu_limit": 1,
    "memory_limit_mb": 2048,
    "disk_limit_mb": 1024,
    "max_processes": 50,
    "max_open_files": 256
  },
  "execution": {
    "timeout_seconds": 300,
    "no_new_privileges": true,
    "allow_sudo": false,
    "allowed_users": ["harness"]
  },
  "security": {
    "seccomp_profile": "seccomp-profile.json",
    "capabilities": ["CHOWN", "SETGID", "SETUID"],
    "dropped_capabilities": [
      "SYS_ADMIN", "NET_ADMIN", "SYS_PTRACE",
      "SYS_RAWIO", "SYS_MODULE", "SYS_BOOT",
      "SYS_TIME", "NET_RAW", "MKNOD",
      "AUDIT_WRITE", "AUDIT_CONTROL", "SETFCAP"
    ]
  }
}
