# Application
APP_NAME=Harness Control Plane
APP_VERSION=1.0.0
DEBUG=false
LOG_LEVEL=INFO

# Database
DATABASE_URL=postgresql+asyncpg://harness:harness@localhost:5432/harness
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=50

# Claude Code / MCP
CLAUDE_API_KEY=sk-f08dfceb34f44b169bea452fab6b0cda
CLAUDE_MODEL=deepseek-v4-pro
MCP_SERVER_URL=http://localhost:3001

# Harness
MAX_ITERATIONS=5
MAX_COST_PER_TASK=5.0
TASK_TIMEOUT_SECONDS=300
RETRY_COUNT=3

# Security
SECRET_KEY=d61e8eb3e56ba1892549bda2c1358fa773f65c5722dc15f84932f55c644f98e4
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Sandbox
SANDBOX_NETWORK_MODE=none
SANDBOX_CPU_LIMIT=1
SANDBOX_MEMORY_LIMIT=2g
SANDBOX_TIMEOUT_SECONDS=300

# Evaluation
TEST_COVERAGE_THRESHOLD=80
SECURITY_SCAN_ENABLED=true
LINT_CHECK_ENABLED=true

# Notifications (optional)
SLACK_WEBHOOK_URL=
SMTP_HOST=
SMTP_PORT=587
